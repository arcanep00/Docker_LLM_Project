# PostgreSQL connection string used by FastAPI, Celery and Alembic.
# When running via docker-compose the host is the "db" service.
DATABASE_URL=postgresql+psycopg2://postgres:postgres@db:5432/transactions

# Redis connection string used as the Celery broker and result backend.
# When running via docker-compose the host is the "redis" service.
REDIS_URL=redis://redis:6379/0

# Google Gemini API key for merchant categorization and summary generation.
# Get one from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Directory where uploaded CSV files are stored.
UPLOAD_DIR=uploads

# Postgres credentials consumed by the docker-compose "db" service.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=transactions
